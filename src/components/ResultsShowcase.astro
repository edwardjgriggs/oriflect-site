---
import ScrollReveal from './ScrollReveal.astro';

const results = [
  {
    scenario: 'Manual Reporting',
    before: '12 hours/week',
    after: '45 minutes/week',
    description: 'Automated data collection and report generation for a 30-person logistics firm',
  },
  {
    scenario: 'Customer Support',
    before: '24-hour response time',
    after: 'Under 2 minutes',
    description: 'AI triage and draft responses for an e-commerce brand handling 200+ tickets/day',
  },
  {
    scenario: 'Lead Qualification',
    before: '15% conversion rate',
    after: '38% conversion rate',
    description: 'AI scoring and routing for a B2B services company with a 5-person sales team',
  },
];
---

<section class="bg-ivory dark:bg-dark-bg py-20 px-6">
  <div class="max-w-7xl mx-auto">
    <ScrollReveal>
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-sapphire dark:text-sapphire-tint text-center mb-4">
        Real Results, Real Businesses
      </h2>
      <p class="font-body text-charcoal/70 dark:text-dark-text/70 text-center max-w-2xl mx-auto mb-16">
        See how AI transforms everyday operations for small and mid-sized teams.
      </p>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {results.map((r, i) => (
        <ScrollReveal delay={(i + 1) * 100}>
          <div class="bg-white dark:bg-dark-surface rounded-xl p-8 shadow-md h-full flex flex-col">
            <h3 class="font-heading font-bold text-lg text-charcoal dark:text-dark-text mb-4">
              {r.scenario}
            </h3>
            <div class="flex items-center gap-4 mb-4">
              <div class="flex-1 text-center">
                <span class="block text-sm font-body text-charcoal/50 dark:text-dark-text/50 uppercase tracking-wide mb-1">Before</span>
                <span class="block font-heading font-bold text-xl text-charcoal/60 dark:text-dark-text/50">{r.before}</span>
              </div>
              <svg class="w-6 h-6 text-ember shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
              <div class="flex-1 text-center">
                <span class="block text-sm font-body text-charcoal/50 dark:text-dark-text/50 uppercase tracking-wide mb-1">After</span>
                <span class="block font-heading font-bold text-xl text-ember">{r.after}</span>
              </div>
            </div>
            <p class="font-body text-charcoal/70 dark:text-dark-text/70 text-sm leading-relaxed mt-auto">
              {r.description}
            </p>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
