---
interface Props {
  posts: any[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="bg-ivory dark:bg-dark-bg py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-sapphire dark:text-sapphire-tint text-center mb-16">
        Latest from the Blog
      </h2>

      <div class:list={[
        'grid gap-8',
        posts.length === 1 ? 'grid-cols-1 max-w-md mx-auto' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3'
      ]}>
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group bg-white dark:bg-dark-surface rounded-xl p-8 shadow-md hover:-translate-y-1 hover:shadow-xl transition-all duration-200 flex flex-col h-full"
          >
            <h3 class="font-heading font-bold text-xl text-sapphire dark:text-sapphire-tint mb-2 group-hover:text-ember transition-colors">
              {post.data.title}
            </h3>
            <p class="font-body text-sm text-charcoal/50 dark:text-dark-text/50 mb-3">
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </p>
            <p class="font-body text-charcoal/70 dark:text-dark-text/70 leading-relaxed mb-4 flex-grow">
              {post.data.description}
            </p>
            <span class="text-ember font-medium group-hover:underline">Read more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
