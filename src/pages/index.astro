---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Strategic AI consulting for small and medium businesses. Discover, implement, and master AI solutions that drive real results.">

  <!-- Hero Section -->
  <section class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-6" style="background: linear-gradient(135deg, #0A2463 0%, #1A3A7A 100%);">
    <div class="text-center max-w-3xl">
      <h1 class="font-heading font-bold text-5xl md:text-6xl text-white leading-tight mb-6">
        Transform Your Operations with AI That Delivers Results
      </h1>
      <p class="font-accent text-xl md:text-2xl text-gold mb-6">
        Strategic AI consulting for small and medium businesses ready to work smarter
      </p>
      <p class="font-body text-lg text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
        From uncovering hidden opportunities to building real automations your team actually uses,
        we partner with you every step of the way. No jargon, no bloat -- just measurable results.
      </p>
      <a
        href="#book"
        class="inline-block bg-ember hover:bg-ember/90 text-white font-body font-medium text-lg px-8 py-4 rounded-lg transition-colors"
      >
        Book a Discovery Call
      </a>
    </div>
  </section>

  <!-- Service Pipeline Section -->
  <section class="bg-ivory dark:bg-dark-bg py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-sapphire dark:text-sapphire-tint text-center mb-16">
        How We Help You Succeed
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr_auto_1fr] gap-y-8 md:gap-y-0 md:gap-x-4 items-stretch">

        <!-- Card 1: AI Discovery Audit -->
        <a href="/services#audit" class="group bg-white dark:bg-dark-surface rounded-xl p-8 shadow-md hover:shadow-lg transition-shadow flex flex-col">
          <div class="mb-4">
            <svg class="w-12 h-12 text-ember" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-charcoal dark:text-dark-text mb-2">AI Discovery Audit</h3>
          <p class="text-gold font-bold mb-3">$500 -- $2,000</p>
          <p class="font-body text-charcoal/70 dark:text-dark-text/70 leading-relaxed mb-4 flex-grow">
            We analyze your workflows, identify where AI can save time and money,
            and deliver a prioritized roadmap with projected ROI for each opportunity.
          </p>
          <span class="text-ember font-medium group-hover:underline">Learn more &rarr;</span>
        </a>

        <!-- Arrow 1 -->
        <div class="hidden md:flex items-center justify-center">
          <svg class="w-8 h-8 text-sapphire/40 dark:text-sapphire-tint/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </div>

        <!-- Card 2: AI Implementation -->
        <a href="/services#implementation" class="group bg-white dark:bg-dark-surface rounded-xl p-8 shadow-md hover:shadow-lg transition-shadow flex flex-col">
          <div class="mb-4">
            <svg class="w-12 h-12 text-ember" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-charcoal dark:text-dark-text mb-2">AI Implementation</h3>
          <p class="text-gold font-bold mb-3">$2,000 -- $10,000</p>
          <p class="font-body text-charcoal/70 dark:text-dark-text/70 leading-relaxed mb-4 flex-grow">
            We build the automations and integrations identified in your audit --
            custom AI tools that slot right into your existing workflows and start saving time on day one.
          </p>
          <span class="text-ember font-medium group-hover:underline">Learn more &rarr;</span>
        </a>

        <!-- Arrow 2 -->
        <div class="hidden md:flex items-center justify-center">
          <svg class="w-8 h-8 text-sapphire/40 dark:text-sapphire-tint/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </div>

        <!-- Card 3: Staff Training -->
        <a href="/services#training" class="group bg-white dark:bg-dark-surface rounded-xl p-8 shadow-md hover:shadow-lg transition-shadow flex flex-col">
          <div class="mb-4">
            <svg class="w-12 h-12 text-ember" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-charcoal dark:text-dark-text mb-2">Staff Training</h3>
          <p class="text-gold font-bold mb-3">Custom pricing</p>
          <p class="font-body text-charcoal/70 dark:text-dark-text/70 leading-relaxed mb-4 flex-grow">
            We equip your team with the skills and confidence to use AI tools effectively --
            hands-on workshops, custom curriculum, and ongoing support so the results stick.
          </p>
          <span class="text-ember font-medium group-hover:underline">Learn more &rarr;</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Why Oriflect Section -->
  <section class="bg-sapphire-tint dark:bg-dark-surface py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-sapphire dark:text-sapphire-tint text-center mb-16">
        Why Oriflect
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">

        <!-- SMB-Focused -->
        <div>
          <div class="flex justify-center mb-4">
            <svg class="w-12 h-12 text-ember" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-charcoal dark:text-dark-text mt-4">SMB-Focused</h3>
          <p class="font-body text-charcoal/70 dark:text-dark-text/70 mt-2 max-w-xs mx-auto">
            Built for businesses with 5 to 200 employees, not enterprise bloat.
            Solutions sized to your team, your budget, and your goals.
          </p>
        </div>

        <!-- End-to-End -->
        <div>
          <div class="flex justify-center mb-4">
            <svg class="w-12 h-12 text-ember" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-charcoal dark:text-dark-text mt-4">End-to-End</h3>
          <p class="font-body text-charcoal/70 dark:text-dark-text/70 mt-2 max-w-xs mx-auto">
            From discovery audit to implementation to training -- one partner for the whole journey.
            No handoffs, no gaps, no starting over.
          </p>
        </div>

        <!-- Measurable ROI -->
        <div>
          <div class="flex justify-center mb-4">
            <svg class="w-12 h-12 text-ember" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-charcoal dark:text-dark-text mt-4">Measurable ROI</h3>
          <p class="font-body text-charcoal/70 dark:text-dark-text/70 mt-2 max-w-xs mx-auto">
            Every recommendation comes with projected returns so you can make informed decisions.
            We track results, not just deliverables.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="py-20 px-6 text-center" style="background: linear-gradient(135deg, #0A2463 0%, #1A3A7A 100%);">
    <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-4">
      Ready to Get Started?
    </h2>
    <p class="font-body text-white/80 text-lg max-w-2xl mx-auto mt-4 mb-10">
      Book a free discovery call and find out how AI can transform your operations.
      No pressure, no jargon -- just an honest conversation about what is possible.
    </p>
    <a
      href="#book"
      class="inline-block bg-ember hover:bg-ember/90 text-white font-body font-medium text-lg px-8 py-4 rounded-lg transition-colors"
    >
      Book a Discovery Call
    </a>
  </section>

</BaseLayout>
