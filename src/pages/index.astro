---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="px-6 py-16 max-w-4xl mx-auto">
    <!-- Hero -->
    <h1 class="font-heading font-bold text-5xl md:text-6xl text-sapphire dark:text-sapphire-tint leading-tight mb-6">
      Oriflect
    </h1>
    <p class="font-accent text-2xl md:text-3xl text-gold mb-8 leading-relaxed">
      AI strategy that transforms how your business operates.
    </p>
    <p class="font-body text-lg text-charcoal dark:text-dark-text leading-relaxed max-w-2xl mb-10">
      We help small and medium businesses discover, implement, and master AI solutions
      that drive real results. From initial audit to staff training, Oriflect is your
      partner in the AI transformation journey.
    </p>

    <!-- CTA Button -->
    <a
      href="#book"
      class="inline-block bg-ember hover:bg-ember/90 text-white font-body font-medium text-lg px-8 py-4 rounded-lg transition-colors mb-16"
    >
      Book a Discovery Call
    </a>

    <!-- Color Demo Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <div class="bg-sapphire text-white p-6 rounded-lg">
        <h3 class="font-heading font-bold text-lg mb-2">Deep Sapphire</h3>
        <p class="text-sm opacity-90">Primary brand color for headers and key elements.</p>
      </div>
      <div class="bg-gold-tint border border-gold/30 p-6 rounded-lg">
        <h3 class="font-heading font-bold text-lg text-charcoal mb-2">Radiant Gold</h3>
        <p class="text-sm text-charcoal/80">Accent color for highlights and dividers.</p>
      </div>
      <div class="bg-sapphire-tint border border-sapphire/20 p-6 rounded-lg">
        <h3 class="font-heading font-bold text-lg text-sapphire mb-2">Sapphire Tint</h3>
        <p class="text-sm text-charcoal/80">Used for subtle backgrounds and table rows.</p>
      </div>
    </div>

    <!-- Font Demo -->
    <div class="space-y-4 mb-16">
      <p class="font-heading font-bold text-2xl text-sapphire dark:text-sapphire-tint">
        Montserrat for Headings
      </p>
      <p class="font-body text-lg text-charcoal dark:text-dark-text">
        Inter for body text and UI elements -- clean and readable at any size.
      </p>
      <p class="font-accent text-xl text-gold italic">
        Playfair Display for accent text and testimonials.
      </p>
      <p class="font-code text-sm bg-charcoal text-ivory dark:bg-dark-surface p-3 rounded">
        JetBrains Mono for code samples and technical content.
      </p>
    </div>

    <!-- Dark Mode Test Section -->
    <div class="bg-white dark:bg-dark-surface border border-sapphire/10 dark:border-white/10 p-8 rounded-lg mb-8">
      <h2 class="font-heading font-bold text-xl text-sapphire dark:text-sapphire-tint mb-4">
        Dark Mode Test
      </h2>
      <p class="text-charcoal dark:text-dark-text mb-6">
        Toggle the theme to verify dark mode colors are applied correctly.
        This card uses <code class="font-code text-sm bg-sapphire-tint dark:bg-dark-bg px-1.5 py-0.5 rounded">dark:bg-dark-surface</code> and <code class="font-code text-sm bg-sapphire-tint dark:bg-dark-bg px-1.5 py-0.5 rounded">dark:text-dark-text</code>.
      </p>
      <button
        id="theme-toggle"
        class="bg-sapphire hover:bg-sapphire/90 dark:bg-gold dark:hover:bg-gold/90 text-white dark:text-charcoal font-body font-medium px-6 py-3 rounded-lg transition-colors"
      >
        Toggle Dark Mode
      </button>
    </div>
  </section>
</BaseLayout>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
