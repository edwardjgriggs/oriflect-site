---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn about Oriflect and our mission to make AI accessible for small and medium businesses.">
  <section class="px-6 py-16 max-w-4xl mx-auto">
    <h1 class="font-heading font-bold text-4xl md:text-5xl text-sapphire dark:text-sapphire-tint mb-6">
      About
    </h1>
    <p class="font-body text-lg text-charcoal/70 dark:text-dark-text/70 leading-relaxed">
      Coming soon -- the story behind Oriflect and our team.
    </p>
  </section>
</BaseLayout>
