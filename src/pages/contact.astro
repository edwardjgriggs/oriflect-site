---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
const calendlyUrl = import.meta.env.PUBLIC_CALENDLY_URL || 'https://calendly.com/oriflect/discovery-call';
---

<BaseLayout title="Contact Us" description="Get in touch with Oriflect or book a free discovery call to discuss your AI consulting needs.">

  <!-- Page Header Banner -->
  <section class="bg-sapphire py-12 md:py-16 px-6 text-center">
    <h1 class="font-heading text-4xl md:text-5xl text-white font-bold">
      Contact Us
    </h1>
    <p class="text-white/80 font-body text-lg mt-4 max-w-2xl mx-auto">
      Get in touch or book a discovery call to explore how AI can transform your business.
    </p>
  </section>

  <!-- Side-by-side: Form + Calendly -->
  <section class="bg-ivory dark:bg-dark-bg py-20 px-6">
    <ScrollReveal>
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- LEFT: Contact Form -->
      <div>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-sapphire dark:text-sapphire-tint mb-2">
          Send Us a Message
        </h2>
        <p class="font-body text-charcoal/70 dark:text-dark-text/70 mb-6">
          Fill out the form and we'll get back to you within 24 hours.
        </p>

        <form id="contact-form" novalidate>
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="New Inquiry from Oriflect Website" />
          <div class="hidden" style="display: none;">
            <input type="checkbox" name="botcheck" />
          </div>

          <!-- Name -->
          <div class="mb-5">
            <label for="name" class="block font-body font-medium text-charcoal dark:text-dark-text mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Your full name"
              class="w-full px-4 py-3 rounded-lg border border-charcoal/20 bg-white dark:bg-dark-surface dark:border-dark-text/20 dark:text-dark-text font-body focus:outline-none focus:ring-2 focus:ring-sapphire transition-colors"
            />
            <p data-error="name" class="text-red-600 text-sm mt-1 hidden">Please enter your name.</p>
          </div>

          <!-- Email -->
          <div class="mb-5">
            <label for="email" class="block font-body font-medium text-charcoal dark:text-dark-text mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@company.com"
              class="w-full px-4 py-3 rounded-lg border border-charcoal/20 bg-white dark:bg-dark-surface dark:border-dark-text/20 dark:text-dark-text font-body focus:outline-none focus:ring-2 focus:ring-sapphire transition-colors"
            />
            <p data-error="email" class="text-red-600 text-sm mt-1 hidden">Please enter a valid email address.</p>
          </div>

          <!-- Company -->
          <div class="mb-5">
            <label for="company" class="block font-body font-medium text-charcoal dark:text-dark-text mb-1">Company</label>
            <input
              type="text"
              id="company"
              name="company"
              required
              placeholder="Your company name"
              class="w-full px-4 py-3 rounded-lg border border-charcoal/20 bg-white dark:bg-dark-surface dark:border-dark-text/20 dark:text-dark-text font-body focus:outline-none focus:ring-2 focus:ring-sapphire transition-colors"
            />
            <p data-error="company" class="text-red-600 text-sm mt-1 hidden">Please enter your company name.</p>
          </div>

          <!-- Message -->
          <div class="mb-6">
            <label for="message" class="block font-body font-medium text-charcoal dark:text-dark-text mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Tell us about your project or question..."
              class="w-full px-4 py-3 rounded-lg border border-charcoal/20 bg-white dark:bg-dark-surface dark:border-dark-text/20 dark:text-dark-text font-body focus:outline-none focus:ring-2 focus:ring-sapphire transition-colors resize-y"
            ></textarea>
            <p data-error="message" class="text-red-600 text-sm mt-1 hidden">Please enter a message.</p>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            disabled
            class="w-full bg-ember hover:bg-ember/90 text-white font-body font-medium px-6 py-3 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send Message
          </button>
        </form>

        <!-- Success State -->
        <div id="form-success" class="hidden text-center py-12">
          <svg class="w-16 h-16 mx-auto text-green-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h3 class="font-heading text-2xl font-bold text-sapphire dark:text-sapphire-tint mb-2">Message Sent!</h3>
          <p class="font-body text-charcoal/70 dark:text-dark-text/70">Thanks! We'll be in touch within 24 hours.</p>
        </div>
      </div>

      <!-- RIGHT: Calendly Inline Embed -->
      <div>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-sapphire dark:text-sapphire-tint mb-2">
          Book a Discovery Call
        </h2>
        <p class="font-body text-charcoal/70 dark:text-dark-text/70 mb-6">
          Schedule a free 30-minute call to discuss your AI needs.
        </p>
        <div
          id="calendly-inline"
          class="min-h-[650px] rounded-lg border border-charcoal/10 dark:border-dark-text/10 overflow-hidden"
        ></div>
      </div>

    </div>
    </ScrollReveal>
  </section>

  <!-- Contact Details Strip -->
  <ScrollReveal>
  <section class="bg-sapphire-tint dark:bg-dark-surface py-12 px-6">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-center gap-8 md:gap-16 text-center">
      <!-- Email -->
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-sapphire dark:text-sapphire-tint flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <a href="mailto:hello@oriflect.com" class="font-body text-charcoal dark:text-dark-text hover:text-sapphire dark:hover:text-sapphire-tint transition-colors">
          hello@oriflect.com
        </a>
      </div>
      <!-- Phone -->
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-sapphire dark:text-sapphire-tint flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        <a href="tel:+15551234567" class="font-body text-charcoal dark:text-dark-text hover:text-sapphire dark:hover:text-sapphire-tint transition-colors">
          (555) 123-4567
        </a>
      </div>
      <!-- Response Time -->
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-sapphire dark:text-sapphire-tint flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="font-body text-charcoal dark:text-dark-text">We respond within 24 hours</span>
      </div>
    </div>
  </section>
  </ScrollReveal>

  <!-- FAQ Section -->
  <section class="bg-ivory dark:bg-dark-bg py-20 px-6">
    <ScrollReveal>
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-sapphire dark:text-sapphire-tint text-center mb-12">
        Frequently Asked Questions
      </h2>

      <div class="space-y-10">
        <div>
          <h3 class="font-heading text-xl font-bold text-charcoal dark:text-dark-text mb-2">
            What is a discovery call?
          </h3>
          <p class="font-body text-charcoal/80 dark:text-dark-text/80 leading-relaxed">
            A free 30-minute conversation where we learn about your business, identify AI opportunities,
            and discuss whether we're a good fit. No commitment required.
          </p>
        </div>

        <div>
          <h3 class="font-heading text-xl font-bold text-charcoal dark:text-dark-text mb-2">
            How long does an AI audit take?
          </h3>
          <p class="font-body text-charcoal/80 dark:text-dark-text/80 leading-relaxed">
            Most audits are completed within 1-2 weeks, depending on the complexity of your operations
            and the number of processes we evaluate.
          </p>
        </div>

        <div>
          <h3 class="font-heading text-xl font-bold text-charcoal dark:text-dark-text mb-2">
            Do I need technical expertise to work with Oriflect?
          </h3>
          <p class="font-body text-charcoal/80 dark:text-dark-text/80 leading-relaxed">
            Not at all. We handle the technical side and explain everything in plain business terms.
            Our training programs ensure your team can confidently use any tools we implement.
          </p>
        </div>
      </div>
    </div>
    </ScrollReveal>
  </section>

  <noscript><style>.scroll-reveal { opacity: 1 !important; transform: none !important; }</style></noscript>

  <!-- Calendly Init Script -->
  <script is:inline>
    window.addEventListener('load', function() {
      var container = document.getElementById('calendly-inline');
      if (container && typeof Calendly !== 'undefined') {
        Calendly.initInlineWidget({
          url: 'https://calendly.com/oriflect/discovery-call',
          parentElement: container,
          prefill: {},
          utm: {}
        });
      }
    });
  </script>

  <!-- Inline Validation Script -->
  <script is:inline>
    (function() {
      var form = document.getElementById('contact-form');
      if (!form) return;

      var touched = new Set();
      var fields = ['name', 'email', 'company', 'message'];

      function validateField(name) {
        var field = form.querySelector('[name="' + name + '"]');
        var errorEl = form.querySelector('[data-error="' + name + '"]');
        if (!field || !errorEl) return false;

        var valid = true;
        if (name === 'email') {
          valid = field.value.trim() !== '' && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value.trim());
        } else {
          valid = field.value.trim() !== '';
        }

        if (!valid && touched.has(name)) {
          field.classList.add('border-red-500');
          field.classList.remove('border-charcoal/20');
          errorEl.classList.remove('hidden');
        } else {
          field.classList.remove('border-red-500');
          field.classList.add('border-charcoal/20');
          errorEl.classList.add('hidden');
        }

        return valid;
      }

      function checkAllValid() {
        var allValid = true;
        for (var i = 0; i < fields.length; i++) {
          if (!validateField(fields[i])) allValid = false;
        }
        var btn = document.getElementById('submit-btn');
        if (btn) btn.disabled = !allValid;
      }

      fields.forEach(function(name) {
        var field = form.querySelector('[name="' + name + '"]');
        if (!field) return;

        field.addEventListener('blur', function() {
          touched.add(name);
          validateField(name);
          checkAllValid();
        });

        field.addEventListener('input', function() {
          if (touched.has(name)) {
            validateField(name);
            checkAllValid();
          }
        });
      });
    })();
  </script>

  <!-- Form Submission Script -->
  <script is:inline>
    (function() {
      var form = document.getElementById('contact-form');
      if (!form) return;

      form.addEventListener('submit', function(e) {
        e.preventDefault();

        var btn = document.getElementById('submit-btn');
        if (btn) {
          btn.disabled = true;
          btn.textContent = 'Sending...';
        }

        var formData = new FormData(form);
        var data = Object.fromEntries(formData);

        fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.success) {
            form.classList.add('hidden');
            var success = document.getElementById('form-success');
            if (success) success.classList.remove('hidden');
          } else {
            throw new Error('Submission failed');
          }
        })
        .catch(function(err) {
          console.error('Form submission error:', err);
          if (btn) {
            btn.disabled = false;
            btn.textContent = 'Send Message';
          }
        });
      });
    })();
  </script>

</BaseLayout>
